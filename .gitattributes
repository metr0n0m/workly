# Normalize line endings to LF on all platforms
* text=auto eol=lf

# PHP / web sources — always LF
*.php   text eol=lf
*.js    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.md    text eol=lf

# Binary — never touch
*.woff2 binary
*.woff  binary
*.ttf   binary
*.eot   binary
*.png   binary
*.jpg   binary
*.ico   binary
